{
  "name": "@xrplens/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "prisma generate",
    "dev": "sh -c 'if [ -f ../../.env ]; then ENV_FILE=../../.env; elif [ -f .env ]; then ENV_FILE=.env; else ENV_FILE=../../.env.example; fi; tsx watch --env-file=$ENV_FILE src/index.ts'",
    "prebuild": "prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@xrplens/core": "workspace:*",
    "bullmq": "^5.30.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.0",
    "openai": "^4.70.0",
    "pdfkit": "^0.18.0",
    "winston": "^3.17.0",
    "xrpl": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
