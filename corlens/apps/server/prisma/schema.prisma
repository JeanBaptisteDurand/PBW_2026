generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Analysis {
  id          String   @id @default(uuid())
  status      String   @default("queued")
  seedAddress String
  seedLabel   String?
  depth       Int      @default(1)
  error       String?
  summaryJson Json?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([seedAddress, depth, status])
  @@index([userId])

  nodes             Node[]
  edges             Edge[]
  riskFlags         RiskFlag[]
  ragDocuments      RagDocument[]
  ragChats          RagChat[]
  complianceReports ComplianceReport[]
}

model Node {
  id            String   @id @default(uuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  nodeId        String
  kind          String
  label         String
  data          Json
  aiExplanation String?
  createdAt     DateTime @default(now())

  @@unique([analysisId, nodeId])
  @@index([analysisId])
}

model Edge {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  edgeId     String
  source     String
  target     String
  kind       String
  label      String?
  data       Json?
  createdAt  DateTime @default(now())

  @@unique([analysisId, edgeId])
  @@index([analysisId])
}

model RiskFlag {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  nodeId     String
  flag       String
  severity   String
  detail     String
  data       Json?
  createdAt  DateTime @default(now())

  @@index([analysisId])
}

model RagDocument {
  id         String                       @id @default(uuid())
  analysisId String
  analysis   Analysis                     @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  @@index([analysisId])
}

model RagChat {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  messages RagMessage[]
}

model RagMessage {
  id        String   @id @default(uuid())
  chatId    String
  chat      RagChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String
  content   String
  sources   Json?
  createdAt DateTime @default(now())
}

model ComplianceReport {
  id         String   @id @default(uuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  title      String
  content    Json
  createdAt  DateTime @default(now())
}

// ─── Corridor atlas ───────────────────────────────────────────
// Cached state of each corridor in the catalog. Refreshed hourly
// by a Bull repeatable job. aiNote is only regenerated when
// liquidityHash changes to save OpenAI spend.
model Corridor {
  id              String   @id // pair slug, e.g. "usd-cny"
  label           String
  shortLabel      String
  flag            String
  tier            Int
  importance      Int
  region          String
  category        String
  description     String
  useCase         String
  highlights      Json
  relatedIds      Json?
  amount          String?
  sourceJson      Json? // CorridorAsset
  destJson        Json? // CorridorAsset
  requestJson     Json? // legacy: representative request (winner's)
  // ── Per-pair winner snapshot (mirrors winning route for fast list reads)
  status          String   @default("UNKNOWN") // GREEN | AMBER | RED | UNKNOWN
  bestRouteId     String?
  pathCount       Int      @default(0)
  recRiskScore    Int?
  recHops         Int?
  recCost         String?
  flagsJson       Json?
  analysisJson    Json?
  liquidityJson   Json?
  // ── Full route comparison
  routesJson      Json? // CorridorRouteResult[]
  // ── AI + caching
  aiNote          String?
  liquidityHash   String? // hash over scan inputs → skip AI regen when unchanged
  aiNoteHash      String?
  lastRefreshedAt DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ragDocuments CorridorRagDocument[]
  ragChats     CorridorRagChat[]
  statusEvents CorridorStatusEvent[]

  @@index([tier])
  @@index([importance])
}

// Append-only status log — one row per refresh per corridor. Powers the
// 30-day status sparkline on the corridor detail page and is the feed
// for future alerting / trend analytics. We intentionally do not dedupe
// consecutive same-status events so the timeline preserves refresh
// cadence; the sparkline component down-samples for display.
model CorridorStatusEvent {
  id          String   @id @default(uuid())
  corridorId  String
  corridor    Corridor @relation(fields: [corridorId], references: [id], onDelete: Cascade)
  status      String // GREEN | AMBER | RED | UNKNOWN
  pathCount   Int      @default(0)
  recCost     String? // winning route source-cost snapshot at this point in time
  source      String   @default("scan") // scan | seed | manual
  at          DateTime @default(now())

  @@index([corridorId, at])
  @@index([at])
}

model CorridorRagDocument {
  id         String                       @id @default(uuid())
  corridorId String
  corridor   Corridor                     @relation(fields: [corridorId], references: [id], onDelete: Cascade)
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  @@index([corridorId])
}

model CorridorRagChat {
  id         String    @id @default(uuid())
  corridorId String? // null ⇒ a "whole atlas" chat
  corridor   Corridor? @relation(fields: [corridorId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  messages CorridorRagMessage[]
}

model CorridorRagMessage {
  id        String          @id @default(uuid())
  chatId    String
  chat      CorridorRagChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String
  content   String
  sources   Json?
  createdAt DateTime        @default(now())

  @@index([chatId])
}

// ─── Safe Path history ────────────────────────────────────────
model SafePathRun {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  srcCcy          String
  dstCcy          String
  amount          String
  maxRiskTolerance String  @default("MED")
  verdict         String   // SAFE | REJECTED | NO_PATHS | OFF_CHAIN_ROUTED
  reasoning       String
  resultJson      Json     // full SafePathResult object
  reportMarkdown  String?  // compliance report markdown
  corridorId      String?  // link to corridor catalog
  analysisIds     Json?    // array of entity analysis IDs
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Payment gate ─────────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  role          String   @default("free") // "free" | "premium"
  apiKey        String?  @unique // API key for MCP / programmatic access (premium only)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions PremiumSubscription[]
  analyses      Analysis[]
  safePathRuns  SafePathRun[]
}

model PremiumSubscription {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  txHash        String   @unique
  amount        String
  currency      String
  walletAddress String
  memo          String   @unique
  paidAt        DateTime @default(now())

  @@index([userId])
  @@index([walletAddress])
}

model PaymentRequest {
  id          String   @id @default(uuid())
  userId      String
  amount      String
  currency    String
  destination String
  memo        String   @unique
  status      String   @default("pending")
  txHash      String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([memo])
  @@index([status])
}
